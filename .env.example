# ─────────────────────────────────────────────────────────────────────────────
# Keeper Network — environment configuration
# Copy this file to .env and fill in the two values marked REQUIRED.
# Everything else has correct defaults for running via docker compose.
# ─────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ─────────────────────────────────────────────────────────────────

# Your Sui wallet private key (hex or suiprivkey... format).
# Generate:  sui keytool generate ed25519
# Export:    sui keytool export --key-identity <alias>
# This never leaves your machine.
SUI_PRIVATE_KEY=

# Your KeeperCredential object ID — minted when you bond 1 SUI on the dashboard.
# Register at the keeper dashboard and copy the credential ID from Step 3.
KEEPER_CREDENTIAL_ID=0x

# ── NETWORK ──────────────────────────────────────────────────────────────────

SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# ── ON-CHAIN OBJECTS (do not change unless redeploying the Move package) ─────

KEEPER_REGISTRY_PKG=0x0fa6730cef35420714275ff33c8ab06bf600a4b459309ab93d2c2fc516496986
KEEPER_REGISTRY_ID=0x4c39bd48039b768fba38d6863acc8ca3c37a9ca3ce6c13e0f41399d6ade9bc90

# ── INFRASTRUCTURE (correct for docker compose; change only for local dev) ───

DATABASE_URL=postgres://keeper:keeper@postgres:5432/keeper
KAFKA_BROKERS=kafka:9092
