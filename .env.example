# Copy this file to .env and fill in real values.
# .env is gitignored and must never be committed.

# Postgres connection string
DATABASE_URL=postgres://keeper:keeper@localhost:5432/keeper

# Kafka brokers (comma-separated)
KAFKA_BROKERS=localhost:9092

# Sui network
SUI_RPC_URL=https://fullnode.testnet.sui.io:443

# Your Sui testnet wallet address
SUI_SIGNER_ADDR=0x

# Your Sui private key as hex (32-byte seed or 64-byte full key)
# Generate with: sui keytool generate ed25519
# Export with: sui keytool export --key-identity <alias>
SUI_PRIVATE_KEY=